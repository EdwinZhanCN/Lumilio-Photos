{
  "name": "lumilio-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:sync": "node scripts/assets-sync.mjs",
    "assets:sync:test": "node --test scripts/assets-sync.test.mjs",
    "e2e:up": "node e2e/support/environment.mjs up",
    "e2e:down": "node e2e/support/environment.mjs down",
    "e2e:logs": "node e2e/support/environment.mjs logs",
    "e2e:seed": "vp run assets:sync && node e2e/support/seed.mjs",
    "e2e:test": "playwright test",
    "demo:seed": "node scripts/demo-seed.mjs",
    "dev": "vp dev",
    "build": "vp build",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "type-check": "vp check --no-fmt --no-lint",
    "check": "vp check",
    "check:boundaries": "node scripts/check-source-boundaries.mjs",
    "fmt": "vp fmt",
    "fmt:fix": "vp fmt . --write",
    "preview": "vp preview",
    "test": "vp test",
    "test:coverage": "vp test run --coverage",
    "test:hash-perf": "VITEST_HASH_PERF=true vp test run src/workers/hash.perf.test.ts",
    "test:watch": "vp test watch",
    "test:browser": "vp run e2e:test --grep @smoke",
    "test:bundle": "vp build && node scripts/check-bundle-budget.mjs",
    "test:ui": "vp test --ui"
  },
  "dependencies": {
    "@immich/justified-layout-wasm": "^0.4.3",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@tanstack/react-query": "^5.74.4",
    "@vidstack/react": "^1.12.13",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^7.0.0",
    "immer": "^11.1.3",
    "katex": "^0.16.22",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.0.0",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^13.0.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.2.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "supercluster": "^8.0.1",
    "swiper": "^12.1.0",
    "tailwindcss": "^4.0.8",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@edwinzhancn/docts": "^0.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^25.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-istanbul": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "daisyui": "^5.5.19",
    "i18next-cli": "^1.58.0",
    "msw": "^2.15.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "1.58.2",
    "typescript": "^5.8.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "^2.2.0",
    "yaml": "^2.8.4",
    "@vitest/browser-playwright": "catalog:"
  },
  "packageManager": "pnpm@11.5.0",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}

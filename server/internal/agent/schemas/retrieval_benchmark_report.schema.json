{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumilio.dev/schemas/agent/retrieval_benchmark_report.schema.json",
  "title": "Retrieval Benchmark Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_at",
    "input_bundle",
    "collection",
    "embedder",
    "limit",
    "ks",
    "query_count",
    "filters_enabled",
    "metrics",
    "latency_ms",
    "per_query"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agent-memory/retrieval-benchmark-report/v1"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "input_bundle": {
      "type": "string"
    },
    "collection": {
      "type": "string"
    },
    "embedder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "base_url", "model", "dimensions"],
      "properties": {
        "provider": { "type": "string" },
        "base_url": { "type": "string" },
        "model": { "type": "string" },
        "dimensions": { "type": "integer", "minimum": 1 }
      }
    },
    "limit": {
      "type": "integer",
      "minimum": 1
    },
    "ks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "query_count": {
      "type": "integer",
      "minimum": 1
    },
    "filters_enabled": {
      "type": "boolean"
    },
    "metrics": {
      "type": "object"
    },
    "latency_ms": {
      "type": "object"
    },
    "per_query": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}

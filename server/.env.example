# Lumilio Photos server process environment template.
#
# Copy to `.env` for local development or export the same variables from your
# shell, process manager, container runtime, or secret manager.
#
# Boundary:
# - This file is not the application runtime config.
# - It provides bootstrap values, deployment wiring, machine-local addresses,
#   and secrets/secret references.
# - Stable application behavior belongs in `config/server.local.toml`.

# Bootstrap profile and config file selection.
SERVER_ENV=development
SERVER_CONFIG_FILE=config/server.local.toml

# Local development PostgreSQL wiring.
# Host machine with the repository dev database:
DB_HOST=localhost
DB_PORT=5433
#
# Dev container / compose network:
# DB_HOST=db
# DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lumiliophotos
DB_SSL=disable

# Optional rotated database password file. When present and non-empty, this
# wins over DB_PASSWORD.
# LUMILIO_DB_PASSWORD_FILE=./data/storage/.secrets/db_password

# App root secret key path, not raw key text. This local development default
# keeps the generated key under the storage secret area.
LUMILIO_SECRET_KEY=./data/storage/.secrets/lumilio_secret_key

# Optional provider secret. Prefer real process env, a local private `.env`, or
# a platform secret manager. Do not commit filled values.
LLM_API_KEY=

# One-shot operator controls such as LUMILIO_BREAK_GLASS should be exported only
# for the command that needs them, not persisted here.

# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development
SERVER_LOG_LEVEL=debug
SERVER_CORS_ALLOWED_ORIGINS=http://localhost:6657,https://localhost:6657

# Database Configuration for Local Development
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lumiliophotos
DB_SSL=disable

# Primary Storage Configuration
# This path should point to the storage root directory.
# The bootstrap process creates/uses the primary repository at STORAGE_PATH/primary.
# Additional repositories should be siblings under this same storage root.
STORAGE_PATH=/PATH/TO/YOUR/ASSETS/
# Storage Strategy Options:
# - date: Organize files by date (YYYY/MM) - user-friendly
# - cas: Content-addressable storage - automatic deduplication
# - flat: All files in single directory
STORAGE_STRATEGY=date
# Filename Handling
STORAGE_PRESERVE_FILENAME=true
# Duplicate Handling Options:
# - rename: Add (1), (2) suffix to duplicates
# - uuid: Add UUID suffix to duplicates
# - overwrite: Replace existing files
STORAGE_DUPLICATE_HANDLING=rename

# Repository Free-Workspace Scanning
# Periodically scans repository roots, excluding .lumilio/** and inbox/**.
# In local development this is usually disabled; use the manual scan API when needed.
REPOSITORY_SCAN_ENABLED=false
# Periodic scan interval in seconds when enabled.
REPOSITORY_SCAN_INTERVAL_SECONDS=300
# Files modified more recently than this are skipped until the next scan.
REPOSITORY_SCAN_SETTLE_SECONDS=5
# Maximum repositories to enqueue per scheduler tick.
REPOSITORY_SCAN_MAX_CONCURRENT_REPOS=1
# Reserved batch size for scanner work chunks.
REPOSITORY_SCAN_BATCH_SIZE=500

# ML Service Configuration
# Enable/disable various ML/AI services
ML_CLIP_ENABLED=false
ML_OCR_ENABLED=false
ML_CAPTION_ENABLED=false
ML_FACE_ENABLED=false

# Secrets
# LUMILIO_SECRET_KEY is a KEY FILE PATH (not raw key text).
# If empty, server auto-generates and persists to:
#   {STORAGE_PATH}/.secrets/lumilio_secret_key
# If STORAGE_PATH ends with /primary, it uses sibling root:
#   {dirname(STORAGE_PATH)}/.secrets/lumilio_secret_key
# This key file is used for:
# - JWT signing key derivation
# - encryption/decryption of persisted sensitive settings (e.g. LLM API key)
LUMILIO_SECRET_KEY=./data/storage/.secrets/lumilio_secret_key

# LLM
LLM_AGENT_ENABLED=false
LLM_PROVIDER=your-llm-provider
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=your-model-name
LLM_BASE_URL=your-openai-compatiable-base-url

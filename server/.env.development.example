# Bootstrap-only development environment.
# Runtime defaults live in config/server.development.toml and can still be
# overridden here when they are machine-specific or secret.

SERVER_ENV=development
SERVER_CONFIG_FILE=config/server.development.toml
SERVER_PORT=6680

# Database (local development)
# Prefer `make env-dev` — it writes .env.development with the correct DB_HOST/DB_PORT
# for your environment. If you copy this file manually, use one of the pairs below.
#
# Host machine (make db-wait / make dev outside the devcontainer):
#   DB_HOST=localhost
#   DB_PORT=5433
#
# Dev Container (inside .devcontainer, DB service on the compose network):
#   DB_HOST=db
#   DB_PORT=5432
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lumiliophotos
DB_SSL=disable

# Primary storage root. The bootstrap process creates/uses the primary
# repository at STORAGE_PATH/primary.
STORAGE_PATH=./data/storage

# Key file path, not raw key text. If empty, the server auto-generates a key
# under {STORAGE_PATH}/.secrets/lumilio_secret_key.
LUMILIO_SECRET_KEY=./data/storage/.secrets/lumilio_secret_key
